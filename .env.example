# dfir-memdump environment configuration
# Copy this file to .env and fill in your values.
# All settings are optional — the tool works out-of-the-box with no .env file.

# ── Volatility3 ───────────────────────────────────────────────────────────────
# Path to the Volatility3 binary. Defaults to 'vol' (assumes it's on PATH).
# Set this if vol is installed somewhere non-standard.
# VOL3_PATH=vol
# VOL3_PATH=/home/user/volatility3/vol.py
# VOL3_PATH=python3 /opt/volatility3/vol.py

# ── VirusTotal (optional) ──────────────────────────────────────────────────────
# Free tier API key from https://www.virustotal.com
# VT lookups are skipped if this is empty or if --no-vt is passed.
VT_API_KEY=

# VT API rate limit (free tier = 4 requests/minute, premium = higher)
# VT_RATE_LIMIT_PER_MINUTE=4

# ── Analysis tunables ─────────────────────────────────────────────────────────
# Shannon entropy threshold for flagging base64/encoded cmdline tokens.
# ENTROPY_THRESHOLD=4.5

# Max number of process images to submit to VirusTotal per run.
# MAX_PROCESSES_TO_HASH=50

# Timeout (seconds) for each Volatility3 plugin invocation.
# PLUGIN_TIMEOUT_SECONDS=300

# ── Threat intel feed ─────────────────────────────────────────────────────────
# How long (hours) to cache the Feodo IP blocklist before re-downloading.
# FEODO_CACHE_TTL_HOURS=6
